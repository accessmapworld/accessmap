# Firebase (https://console.firebase.google.com → Project settings → Web app)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Roboflow inference (https://roboflow.com → your model → Deploy → Hosted API)
VITE_ROBOFLOW_API_KEY=
VITE_ROBOFLOW_MODEL=accessibility-features/3

# When any Firebase var is missing the app runs on bundled mock data so the
# UI is fully explorable without a backend.
